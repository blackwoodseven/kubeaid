<?xml version="1.0" encoding="UTF-8" ?>
<configuration debug={{ .Values.logging.debug | quote }}>

  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  <!--                              File Appender                              -->
  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  {{- if .Values.logging.root.file }}
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>/var/log/open-xchange/documents-collaboration/documents-collaboration.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>/var/log/open-xchange/documents-collaboration/documents-collaboration.log.%d{yyyy-MM-dd}.%i</fileNamePattern>
      <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
        <maxFileSize>{{ .Values.logging.maxFileSize }}</maxFileSize>
      </timeBasedFileNamingAndTriggeringPolicy>
      <maxHistory>{{ .Values.logging.maxIndex }}</maxHistory>
    </rollingPolicy>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>%-4r [%t] %5p %c{1} - %m %mdc %n</pattern>
    </encoder>
  </appender>

  <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
    <queueSize>{{ .Values.logging.queueSize }}</queueSize>
    <discardingThreshold>0</discardingThreshold>
    <includeCallerData>true</includeCallerData>
    <appender-ref ref="FILE"/>
  </appender>
  {{ end }}

  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  <!--                             Syslog Appender                             -->
  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  {{- if .Values.logging.root.syslog }}
  <appender name="SYSLOG" class="ch.qos.logback.classic.net.SyslogAppender">
    <syslogHost>{{ .Values.logging.syslog.host }}</syslogHost>
    <port>{{ .Values.logging.syslog.port }}</port>
    <facility>{{ .Values.logging.syslog.facility }}</facility>
    <suffixPattern>%date open-xchange %-5level [%logger][%thread]: %class.%method\(%class{0}.java:%line\)%n%lmdc %n %sanitisedMessage%n</suffixPattern>
  </appender>
  {{ end }}

  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  <!--                            Console Appender                             -->
  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  {{- if .Values.logging.root.console }}
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
      <layout class="com.openxchange.office.dcs.logback.json.extension.DcsJsonLayout">
        <jsonFormatter class="ch.qos.logback.contrib.jackson.JacksonJsonFormatter">
          <prettyPrint>false</prettyPrint>
        </jsonFormatter>
        <timestampFormat>yyyy-MM-dd'T'HH:mm:ss,SSSZ</timestampFormat>
        <timestampFormatTimezoneId>Etc/UTC</timestampFormatTimezoneId>
        <includeReadableTimestamp>true</includeReadableTimestamp>
        <includeLogLevelName>true</includeLogLevelName>
        <includeLoggerName>true</includeLoggerName>
        <appendLineSeparator>true</appendLineSeparator>
      </layout>
    </encoder>
  </appender>

  <appender name="ASYNC_STDOUT" class="ch.qos.logback.classic.AsyncAppender">
    <queueSize>{{ .Values.logging.queueSize }}</queueSize>
    <discardingThreshold>0</discardingThreshold>
    <includeCallerData>true</includeCallerData>
    <appender-ref ref="STDOUT"/>
  </appender>
  {{ end }}

  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  <!--                            Logstash Appender                            -->
  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  {{- if .Values.logging.root.logstash }}
  <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
    <destination>{{ .Values.logging.logstash.host }}:{{ .Values.logging.logstash.port }}</destination>
    <encoder class="net.logstash.logback.encoder.LogstashEncoder" />
  </appender>
  {{ end }}

  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  <!--                               SpringBoot                               -->
  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  <include resource="org/springframework/boot/logging/logback/defaults.xml" />

  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  <!--                               Root Logger                               -->
  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  <root level={{ .Values.logging.root.level | quote }}>
  {{- if .Values.logging.root.console }}
    <appender-ref ref="ASYNC_STDOUT" />
  {{- end }}
  {{- if .Values.logging.root.logstash }}
    <appender-ref ref="LOGSTASH" />
  {{- end }}
  {{- if .Values.logging.root.syslog }}
    <appender-ref ref="SYSLOG" />
  {{- end }}
  {{- if .Values.logging.root.file }}
    <appender-ref ref="ASYNC_FILE" />
  {{- end }}
  </root>

  <logger name="sun.rmi" level="INFO"/>
  <logger name="org.apache" level="WARN"/>
  <logger name="com.sun" level="INFO"/>
  <logger name="javax.management" level="INFO"/>
  <logger name="javax.jmdns" level="WARN"/>
  <logger name="liquibase.ext.logging.slf4j.Slf4jLogger" level="WARN"/>

  <logger name="com.openxchange" level="INFO"/>
  <logger name="com.openxchange.office.dcs" level="INFO"/>
  <logger name="com.springframework" level="INFO"/>
  <logger name="org.apache.activemq.transport.AbstractInactivityMonitor" level="INFO"/>
  <logger name="org.apache.activemq" level="INFO"/>
  <logger name="com.openxchange.office.dcs.config.ConfigReader" level="INFO"/>

  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  <!--                                 Logger                                  -->
  <!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  {{- range .Values.logging.logger }}
  <logger name={{ .name | quote }} level={{ .level | quote }}/>
  {{- end }}

</configuration>
