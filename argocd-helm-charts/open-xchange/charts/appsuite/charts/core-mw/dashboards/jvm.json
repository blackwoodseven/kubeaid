   "templating": {
      "list": [
         {
            "name": "datasource",
            "query": "prometheus",
            "type": "datasource"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${datasource}"
            },
            "name": "namespace",
            "query": "label_values(appsuite_version_info, namespace)",
            "refresh": 2,
            "sort": 1,
            "type": "query"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${datasource}"
            },
            "hide": 2,
            "name": "app",
            "query": "label_values(up{namespace=\"$namespace\"}, app)",
            "refresh": 2,
            "regex": "/.*core-mw.*/",
            "sort": 1,
            "type": "query"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${datasource}"
            },
            "name": "pod",
            "query": "label_values(appsuite_version_info{namespace=\"$namespace\", app=~\".*$app.*\"}, pod)",
            "refresh": 2,
            "sort": 1,
            "type": "query"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${datasource}"
            },
            "hide": 2,
            "includeAll": true,
            "name": "mem_pools_heap",
            "query": "label_values(jvm_memory_used_bytes{pod=~\"$pod\", area=\"heap\"}, id)",
            "type": "query"
         },
         {
            "datasource": {
               "type": "prometheus",
               "uid": "${datasource}"
            },
            "hide": 2,
            "includeAll": true,
            "name": "mem_pools_nonheap",
            "query": "label_values(jvm_memory_used_bytes{pod=~\"$pod\", area=\"nonheap\"}, id)",
            "type": "query"
         }
      ]
